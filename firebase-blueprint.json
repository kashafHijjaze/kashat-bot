{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing roles and identification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "passwordHash": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "googleId": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "email", "name", "role", "createdAt"]
    },
    "Session": {
      "title": "Session",
      "description": "WhatsApp session sync state",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["connected", "disconnected", "connecting"] },
        "pairedAt": { "type": "string" },
        "sessionToken": { "type": "string" }
      },
      "required": ["userId", "email", "status"]
    },
    "Log": {
      "title": "Log",
      "description": "System and user action log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "action": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "userId", "email", "action", "message", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "sessions/{userId}": {
      "schema": "Session",
      "description": "WhatsApp sessions"
    },
    "logs/{logId}": {
      "schema": "Log",
      "description": "System activity logs"
    }
  }
}
